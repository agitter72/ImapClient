@using System.Globalization
@inject NavigationManager Navigation

<div class="culture-selector">
    <select @onchange="OnCultureChanged" value="@selectedCulture">
        <option value="en">English</option>
        <option value="de">Deutsch</option>
    </select>
</div>

@code {
    private string selectedCulture = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;

    private void OnCultureChanged(ChangeEventArgs e)
    {
        var culture = e.Value?.ToString() ?? "en";
        selectedCulture = culture;

        var uri = new Uri(Navigation.Uri)
                    .GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        var query = $"?culture={culture}";

        Navigation.NavigateTo($"{uri}{query}", forceLoad: true);
    }
}