@using ImapClient.Web.Resources
@using Microsoft.Extensions.Localization
@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> Localizer

<div class="app-shell">
    <header class="app-header">
        <div>
            <p class="app-kicker">ImapClient</p>
            <h1>@Localizer["AppTitle"]</h1>
        </div>
        <div class="header-actions">
            <CultureSelector />
            @* <a class="header-link" href="https://learn.microsoft.com/aspnet/core/" target="_blank">@Localizer["BlazorDocs"]</a> *@
        </div>
    </header>

    <main class="app-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Localizer["ErrorOccurred"]
    <a href="." class="reload">@Localizer["Reload"]</a>
    <span class="dismiss">🗙</span>
</div>