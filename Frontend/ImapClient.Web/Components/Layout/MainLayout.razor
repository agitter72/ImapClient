@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <div>
            <p class="app-kicker">ImapClient</p>
            <h1>Outlook 365 inbox command center</h1>
        </div>
        <a class="header-link" href="https://learn.microsoft.com/aspnet/core/" target="_blank">Blazor docs</a>
    </header>

    <main class="app-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
